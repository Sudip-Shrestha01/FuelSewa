{
  "expo": {
    "name": "fuelsewa-mobile",
    "slug": "fuelsewa-mobile",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "light",
    "extra": {
      "apiUrl": "https://fuelsewa.onrender.com/api",
      "eas": {
        "projectId": "ed5875ee-5b70-47fa-89bf-5777a1e62be9"
      }
    },
    "splash": {
      "image": "./assets/splash-icon.png",
      "resizeMode": "contain",
      "backgroundColor": "#ffffff"
    },
    "android": {
      "adaptiveIcon": {
        "backgroundColor": "#E6F4FE",
        "foregroundImage": "./assets/android-icon-foreground.png",
        "backgroundImage": "./assets/android-icon-background.png",
        "monochromeImage": "./assets/android-icon-monochrome.png"
      },
      "predictiveBackGestureEnabled": false,
      "package": "com.anonymous.fuelsewamobile",
      "permissions": [
        "ACCESS_FINE_LOCATION",
        "ACCESS_COARSE_LOCATION",
        "android.permission.ACCESS_COARSE_LOCATION",
        "android.permission.ACCESS_FINE_LOCATION"
      ],
      "softwareKeyboardLayoutMode": "pan"
    },
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.anonymous.fuelsewa-mobile",
      "infoPlist": {
        "NSLocationWhenInUseUsageDescription": "FuelSewa needs your location to detect your delivery address.",
        "NSLocationAlwaysUsageDescription": "FuelSewa needs your location to detect your delivery address."
      }
    },
    "web": {
      "favicon": "./assets/favicon.png"
    },
    "plugins": [
      [
        "expo-location",
        {
          "locationWhenInUsePermission": "FuelSewa needs your location to detect your delivery address."
        }
      ],
      [
        "expo-notifications",
        {
          "icon": "./assets/icon.png",
          "color": "#1D9E75",
          "sounds": [
            "./assets/notification.wav"
          ],
          "androidMode": "default",
          "androidCollapsedTitle": "FuelSewa"
        }
      ]
    ]
  }
}
